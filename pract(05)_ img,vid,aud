import pandas as pd
from google.colab import files

uploaded = files.upload()   # ✅ only once

# 🖼️ IMAGE → HORUS
for name in uploaded.keys():
    df = pd.DataFrame([[name, "image", len(uploaded[name])]],
                      columns=["filename", "filetype", "filesize"])

print("IMAGE HORUS")
print(df)

